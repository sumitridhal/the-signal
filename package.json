{
  "name": "the-signal",
  "private": false,
  "version": "0.1.0",
  "description": "A forkable static RSS newspaper homepage for GitHub Pages.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "fetch-feeds": "tsx scripts/fetch-feeds.ts",
